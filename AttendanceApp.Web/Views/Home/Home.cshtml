@using AttendanceApp.Domain.Enums
@model AttendanceApp.Web.Models.HomeViewModel
@{
    ViewData["Title"] = "Home";
}
<link rel="stylesheet" href="~/css/home.css" />
<nav class="navbar">
    <div class="nav-left">
        <span class="navbar-brand">AttendanceApp</span>
    </div>

    <div class="nav-right">
        <!-- Search -->
        <input type="search"
               class="nav-search"
               placeholder="Search" />

        <!-- Profile button -->
        <button class="profile-btn" aria-label="Profile">
            <i class="bi bi-person"></i>
        </button>
    </div>
</nav>

<div class="container mt-4">
    @if (Model.UserType == UserType.Student)
    {
        <partial name="_StudentHome" model="Model.Student" />
    }
    else if (Model.UserType == UserType.Admin)
    {
        <partial name="_AdminHome" model="Model.Admin" />
    }
    else
    {
        <div class="alert alert-warning">
            Unknown user role.
        </div>
    }
</div>
