@using AttendanceApp.Domain.Enums
@model AttendanceApp.Web.Models.HomeViewModel
@{
    ViewData["Title"] = "Home";
    Layout = "_HomeLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}
<nav class="navbar">
    <div class="nav-left">
        <span class="navbar-brand">AttendanceApp</span>
    </div>

    <div class="nav-right">
        <!-- Quizzes button (professors only) -->
        @if (Model.UserType == UserType.Professor)
        {
            <button id="quizzesBtn" class="calendar-btn" aria-label="Quizzes" type="button">Quizzes</button>
        }
        <!-- Calendar button -->
        <button id="calendarBtn" class="calendar-btn" aria-label="Calendar" type="button">Calendar</button>
        <!-- Search -->
        <div class="search-container">
            <input type="search"
                   id="userSearch"
                   class="nav-search"
                   placeholder="Search users..."
                   autocomplete="off" />
            <div id="searchResults" class="search-results" aria-hidden="true"></div>
        </div>

        <!-- Profile button -->
        @{
          var parts = Model.UserName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
          string initials;
          if (parts.Length >= 2)
          {
            initials = $"{parts[0][0]}{parts[^1][0]}";
          }
          else if (!string.IsNullOrEmpty(Model.UserName))
          {
            initials = Model.UserName[0].ToString();
          }
          else
          {
            initials = "?";
          }
        }
        <a href="/profile/me" class="profile-btn" aria-label="Profile">
            <span class="profile-initials">@initials.ToUpper()</span>
        </a>
    </div>
</nav>

<div class="container mt-4">
    @if (Model.UserType == UserType.Student)
    {
        @await Html.PartialAsync("_StudentHome")
        <script src="~/js/student-home.js" asp-append-version="true"></script>
    }
    else if (Model.UserType == UserType.Professor)
    {
        @await Html.PartialAsync("_ProfessorHome")
        <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
        <script src="~/js/professor-home.js" asp-append-version="true"></script>
        <script src="~/js/home-quizzes.js" asp-append-version="true"></script>
    }
    else if (Model.UserType == UserType.Admin)
    {
        @await Html.PartialAsync("_AdminHome")
    }
    else
    {
        <div class="alert alert-warning">
            Unknown user role.
        </div>
    }

    
</div>

<!-- Calendar popover -->
<div id="calendarPopover" class="cal-popover" aria-hidden="true">
  <div class="cal-head">
    <div class="cal-title">
      <button type="button" class="cal-nav" data-cal-prev aria-label="Previous month">‹</button>
      <span data-cal-month></span>
      <button type="button" class="cal-nav" data-cal-next aria-label="Next month">›</button>
    </div>

    <div class="cal-actions">
      <button type="button" class="cal-today" data-cal-today>Today</button>
      <button type="button" class="cal-close" data-cal-close aria-label="Close">✕</button>
    </div>
  </div>

  <div class="cal-body">
    <!-- Month -->
    <div class="cal-month">
      <div class="cal-dow">
        <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
      </div>
      <div class="cal-grid" data-cal-grid></div>
    </div>
    <!-- Day timeline -->
    <div class="cal-day">
      <div class="cal-day-head">
        <span data-cal-daylabel></span>
      </div>
      <div class="cal-timeline">
        <div class="cal-hours" data-cal-hours></div>
        <div class="cal-events" data-cal-events></div>
      </div>
    </div>
  </div>
</div>

<!-- Quizzes popover (professors only) -->
@if (Model.UserType == UserType.Professor)
{
<div id="quizzesPopover" class="quiz-popover" aria-hidden="true">
  <div class="quiz-head">
    <div class="quiz-title">
      <span id="quizTitleText">My Quizzes</span>
    </div>
    <div class="quiz-head-actions">
      <button type="button" class="quiz-action-btn" id="createQuizBtn" title="New Quiz">
        <span class="plus-icon">+</span>
        <span>New</span>
      </button>
      <button type="button" class="quiz-close" data-quiz-close aria-label="Close">✕</button>
    </div>
  </div>

  <div class="quiz-search">
    <input type="text" 
           class="quiz-search-input" 
           id="quizSearchInput" 
           placeholder="Search quizzes..." 
           autocomplete="off" />
  </div>
  <div class="quiz-body">
    <div class="quiz-list" id="quizList" aria-live="polite"></div>
  </div>
</div>

<!-- Create Quiz Modal -->
<div class="quiz-editor-modal" id="createQuizModal" aria-hidden="true">
  <div class="quiz-editor-backdrop" data-close-create-modal></div>
  <div class="quiz-editor-content">
    <form id="createQuizForm" onsubmit="event.preventDefault();">
      <div class="quiz-editor-header">
        <h2 class="quiz-editor-title">Create Quiz</h2>
        <button type="button" class="quiz-editor-close" data-close-create-modal aria-label="Close">✕</button>
      </div>
      <div class="quiz-editor-body">
        <div class="qe-field">
          <label class="qe-label" for="quizName">Quiz Name</label>
          <input class="qe-input" id="quizName" name="name" required />
        </div>
        <div class="qe-field">
          <label class="qe-label" for="quizDuration">Duration</label>
          <input type="text" class="qe-input" id="quizDuration" name="duration" placeholder="e.g. 15m | 1h30m" required />
        </div>
      </div>
      <div class="quiz-editor-footer">
        <div id="createQuizFeedback" class="qe-feedback" aria-live="polite"></div>
        <div class="qe-actions">
          <button type="button" class="qe-btn qe-btn-secondary" data-close-create-modal>Cancel</button>
          <button type="submit" class="qe-btn qe-btn-primary">Create</button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Edit Quiz Modal -->
<div class="quiz-editor-modal" id="editQuizModal" aria-hidden="true">
  <div class="quiz-editor-backdrop" data-close-edit-modal></div>
  <div class="quiz-editor-content quiz-editor-content--large">
    <div class="quiz-editor-header">
      <div class="quiz-editor-title-wrap">
        <input type="text" class="quiz-editor-name-input" id="editQuizName" placeholder="Quiz name..." />
        <input type="text" class="quiz-editor-duration-input" id="editQuizDuration" placeholder="Duration (e.g. 15m)" />
      </div>
      <button type="button" class="quiz-editor-close" id="editQuizCloseBtn" aria-label="Close">✕</button>
    </div>
    <div class="quiz-editor-body quiz-editor-body--scroll" id="editQuizBody">
      <!-- Questions rendered here -->
    </div>
    <div class="quiz-editor-warnings" id="editQuizWarnings">
      <!-- Warnings rendered here -->
    </div>
    <div class="quiz-editor-footer">
      <button type="button" class="qe-btn qe-btn-add" id="addQuestionBtn">
        <span class="plus-icon">+</span>
        <span>Add Question</span>
      </button>
      <div class="qe-actions">
        <button type="button" class="qe-btn qe-btn-primary" id="editQuizDoneBtn">Done</button>
      </div>
    </div>
  </div>
</div>
}

<!-- Lecture action modal -->
<div class="modal fade" id="lectureActionModal" tabindex="-1" aria-labelledby="lectureActionModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="lectureActionModalLabel">Lecture</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="lectureInfo">
          <p><strong id="lecTitle">Title</strong></p>
          <p id="lecTime" class="small text-muted"></p>
          <p id="lecDesc" class="small"></p>
          <p>Current status: <span id="lecStatus" class="small"></span></p>
        </div>
        <div id="lectureActionFeedback" class="form-feedback" aria-live="polite"></div>
      </div>
      <div class="modal-footer">
        <div id="lectureActionButtons" class="d-flex gap-2"></div>
        <button type="button" class="btn-inline" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script src="~/js/home.js" asp-append-version="true"></script>
}
