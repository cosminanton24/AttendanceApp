@model AttendanceApp.Web.Models.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "_ProfileLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="profile-page">
    <!-- Header / Navigation -->
    <nav class="profile-nav">
        <a href="/home/index" class="back-btn" aria-label="Back">
            <span class="back-icon">←</span>
        </a>
        <span class="nav-title">My Profile</span>
        <div class="nav-spacer"></div>
    </nav>

    @await Html.PartialAsync("_ProfileCard", Model)
</div>

@await Html.PartialAsync("_UsersModal")

@section Scripts {
    <script>
        window.profileData = {
            userId: "@Model.UserId",
            isOwnProfile: true
        };
    </script>
    <script src="~/js/profile.js" asp-append-version="true"></script>
}
