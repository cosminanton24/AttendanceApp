@{
    ViewData["Title"] = "Login";
}

<div class="wrap">
  <div class="card">
    <h1>Login</h1>
    <p class="sub">Welcome back.</p>

    <div id="err" class="err" hidden></div>

    <form id="loginForm">
      <div class="field">
        <label for="email">Email</label>
        <input id="email" type="email" autocomplete="email" required />
      </div>

      <div class="field">
        <label for="password">Password</label>
        <input id="password" type="password" autocomplete="current-password" required />
      </div>

      <button class="btn" type="submit">Sign in</button>
    </form>

    <p class="hint">No account? <a href="/auth/register">Register</a></p>
  </div>
</div>

<style>
  :root{ --bg:#070a12; --card:#0b1220; --stroke:rgba(255,255,255,.08); --text:#e7eefc; --muted:#9fb0c6; }
  body{ margin:0; min-height:100vh; color:var(--text);
    background:
      radial-gradient(900px 500px at 20% 10%, rgba(59,130,246,.18), transparent 55%),
      radial-gradient(900px 500px at 80% 90%, rgba(96,165,250,.14), transparent 55%),
      linear-gradient(180deg, var(--bg), #0b1220);
  }
  .wrap{ min-height:100vh; display:grid; place-items:center; padding:24px; }
  .card{ width:min(420px, 100%); background:rgba(11,18,32,.72); border:1px solid var(--stroke);
    border-radius:18px; padding:22px; box-shadow:0 24px 80px rgba(0,0,0,.55); backdrop-filter: blur(10px);
  }
  h1{ margin:0 0 6px; font-size:24px; }
  .sub{ margin:0 0 16px; color:var(--muted); font-size:13px; }
  .field{ display:flex; flex-direction:column; gap:8px; margin:12px 0; }
  label{ color:var(--muted); font-size:13px; }
  input{ padding:12px; border-radius:12px; border:1px solid rgba(255,255,255,.09);
    background:rgba(7,10,18,.65); color:var(--text); outline:none;
  }
  input:focus{ border-color:rgba(96,165,250,.55); box-shadow:0 0 0 5px rgba(59,130,246,.14); }
  .btn{ width:100%; margin-top:10px; border:0; cursor:pointer; padding:12px 14px; border-radius:14px;
    font-weight:800; color:#071022; background:linear-gradient(90deg,#3b82f6,#60a5fa);
  }
  .err{ margin:10px 0; padding:10px; border-radius:12px; border:1px solid rgba(96,165,250,.35);
    background:rgba(59,130,246,.12);
  }
  .hint{ margin-top:12px; color:var(--muted); font-size:13px; text-align:center; }
  .hint a{ color:#60a5fa; text-decoration:none; font-weight:800; }

  select{
  padding:12px;
  border-radius:12px;
  border:1px solid rgba(255,255,255,.09);
  background:
    linear-gradient(180deg, rgba(7,10,18,.65), rgba(7,10,18,.65));
  color:var(--text);
  outline:none;
  appearance:none;          /* remove default arrow */
  -webkit-appearance:none;
  -moz-appearance:none;
  cursor:pointer;
}

/* custom dropdown arrow */
.field{
  position:relative;
}

.field select{
  padding-right:40px;
}

.field::after{
  content:"▾";
  position:absolute;
  right:14px;
  top:50%;
  transform:translateY(-50%);
  pointer-events:none;
  color:var(--muted);
  font-size:14px;
}

select:focus{
  border-color:rgba(96,165,250,.55);
  box-shadow:0 0 0 5px rgba(59,130,246,.14);
}

/* dropdown options (limited styling, browser-dependent) */
option{
  background:#0b1220;
  color:var(--text);
}

</style>

<script>
  const form = document.getElementById("loginForm");
  const err = document.getElementById("err");

  function showError(message) {
    err.textContent = message;
    err.hidden = false;
  }

  function clearError() {
    err.hidden = true;
    err.textContent = "";
  }

  function extractErrorMessage(data) {
    // 1) ASP.NET Core model validation format:
    // { title, status, errors: { Field: [msg], ... } }
    if (data?.errors && typeof data.errors === "object") {
      for (const [field, arr] of Object.entries(data.errors)) {
        if (Array.isArray(arr) && arr.length) {
          return arr[0]; // first message is usually best
        }
      }
    }

    // 2) Your custom ProblemDetails mapping with extensions.errors :contentReference[oaicite:1]{index=1}
    if (data?.extensions?.errors?.length) {
      return data.extensions.errors[0].message;
    }

    // 3) Standard ProblemDetails detail
    if (data?.detail) return data.detail;

    // 4) Sometimes servers use title for the message
    if (data?.title && typeof data.title === "string") return data.title;

    return null;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearError();

    const payload = {
      email: document.getElementById("email").value.trim(),
      password: document.getElementById("password").value
    };

    let res;
    try {
      res = await fetch("/api/users/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        body: JSON.stringify(payload)
      });
    } catch {
      showError("Network error. Please check your connection and try again.");
      return;
    }

    if (!res.ok) {
      // try JSON first
      try {
        const data = await res.json();
        const msg = extractErrorMessage(data);

        // nice generic mapping for common statuses (optional)
        if (!msg) {
          if (res.status === 401) return showError("Invalid email or password.");
          if (res.status === 403) return showError("You don’t have access to sign in.");
          showError("Login failed. Please try again.");
          return;
        }

        showError(msg);
        return;
      } catch {
        // not JSON — avoid dumping raw response
        if (res.status === 401) return showError("Invalid email or password.");
        showError("Login failed. Please try again.");
        return;
      }
    }

    window.location.href = "/home/index";
  });
</script>

