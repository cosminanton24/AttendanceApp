@{ 
    ViewData["Title"] = "Register";
    Layout = "_AuthLayout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}
<div class="wrap">
  <div class="card">
    <h1>Register</h1>
    <p class="sub">Create your account.</p>

    <div id="err" class="err" hidden></div>

    <form id="registerForm">
      <div class="field">
        <label for="name">Name</label>
        <input id="name" required />
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input id="email" type="email" required />
      </div>

      <div class="field">
        <label for="password">Password</label>
        <input id="password" type="password" required />
      </div>

      <div class="field">
        <label for="userType">User type</label>
        <select id="userType">
          <option value="Student">Student</option>
          <option value="Professor">Professor</option>
        </select>
      </div>

      <button class="btn" type="submit">Create account</button>
    </form>

    <p class="hint">Have an account? <a href="/auth/login">Login</a></p>
  </div>
</div>


<script>
  const form = document.getElementById("registerForm");
  const err = document.getElementById("err");

  function showError(message) {
    err.textContent = message;
    err.hidden = false;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    err.hidden = true;
    err.textContent = "";

    const payload = {
      name: document.getElementById("name").value.trim(),
      email: document.getElementById("email").value.trim(),
      password: document.getElementById("password").value,
      userType: document.getElementById("userType").value
    };

    let res;
    try {
      res = await fetch("/api/users/register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        body: JSON.stringify(payload)
      });
    } catch {
      showError("Network error. Please check your connection and try again.");
      return;
    }

    if (!res.ok) {
  let data = null;

  // Try to read JSON, but don't crash if it isn't JSON
  try {
    data = await res.json();
  } catch {
    showError("Registration failed. Please try again.");
    return;
  }

  // ✅ 1) ASP.NET Core validation errors: { errors: { Field: [msg] } }
  if (data?.errors && typeof data.errors === "object") {
    const msgs = [];

    for (const [field, arr] of Object.entries(data.errors)) {
      if (Array.isArray(arr) && arr.length) {
        // field might be "$" or "request" etc — ignore name, show message
        msgs.push(arr[0]);
      }
    }

    if (msgs.length) {
      showError(msgs[0]); // or msgs.join("\n") if you want multiple
      return;
    }
  }

  // ✅ 2) Your custom ProblemDetails mapping (from ResultActionResultExtensions)
  if (data?.extensions?.errors?.length) {
    showError(data.extensions.errors[0].message);
    return;
  }

  if (data?.detail) {
    showError(data.detail);
    return;
  }

  // ✅ 3) Final fallback
  showError("Registration failed. Please try again.");
  return;
}

    // success → go to login
    window.location.href = "/auth/login";
  });
</script>

