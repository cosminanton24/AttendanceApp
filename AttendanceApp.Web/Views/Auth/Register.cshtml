@{
    ViewData["Title"] = "Register";
}

<div class="wrap">
  <div class="card">
    <h1>Register</h1>
    <p class="sub">Create your account.</p>

    <div id="err" class="err" hidden></div>

    <form id="registerForm">
      <div class="field">
        <label for="name">Name</label>
        <input id="name" required />
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input id="email" type="email" required />
      </div>

      <div class="field">
        <label for="password">Password</label>
        <input id="password" type="password" required />
      </div>

      <div class="field">
        <label for="userType">User type</label>
        <select id="userType">
          <option value="Student">Student</option>
          <option value="Teacher">Teacher</option>
        </select>
      </div>

      <button class="btn" type="submit">Create account</button>
    </form>

    <p class="hint">Have an account? <a href="/auth/login">Login</a></p>
  </div>
</div>

<style>
  :root{ --bg:#070a12; --card:#0b1220; --stroke:rgba(255,255,255,.08); --text:#e7eefc; --muted:#9fb0c6; }
  body{ margin:0; min-height:100vh; color:var(--text);
    background:
      radial-gradient(900px 500px at 20% 10%, rgba(59,130,246,.18), transparent 55%),
      radial-gradient(900px 500px at 80% 90%, rgba(96,165,250,.14), transparent 55%),
      linear-gradient(180deg, var(--bg), #0b1220);
  }
  .wrap{ min-height:100vh; display:grid; place-items:center; padding:24px; }
  .card{ width:min(420px, 100%); background:rgba(11,18,32,.72); border:1px solid var(--stroke);
    border-radius:18px; padding:22px; box-shadow:0 24px 80px rgba(0,0,0,.55); backdrop-filter: blur(10px);
  }
  h1{ margin:0 0 6px; font-size:24px; }
  .sub{ margin:0 0 16px; color:var(--muted); font-size:13px; }
  .field{ display:flex; flex-direction:column; gap:8px; margin:12px 0; }
  label{ color:var(--muted); font-size:13px; }
  input{ padding:12px; border-radius:12px; border:1px solid rgba(255,255,255,.09);
    background:rgba(7,10,18,.65); color:var(--text); outline:none;
  }
  input:focus{ border-color:rgba(96,165,250,.55); box-shadow:0 0 0 5px rgba(59,130,246,.14); }
  .btn{ width:100%; margin-top:10px; border:0; cursor:pointer; padding:12px 14px; border-radius:14px;
    font-weight:800; color:#071022; background:linear-gradient(90deg,#3b82f6,#60a5fa);
  }
  .err{ margin:10px 0; padding:10px; border-radius:12px; border:1px solid rgba(96,165,250,.35);
    background:rgba(59,130,246,.12);
  }
  .hint{ margin-top:12px; color:var(--muted); font-size:13px; text-align:center; }
  .hint a{ color:#60a5fa; text-decoration:none; font-weight:800; }
  /* inputs + select share the same base style */
input,
select{
  padding:12px;
  border-radius:12px;
  border:1px solid rgba(255,255,255,.09);
  background:rgba(7,10,18,.65);
  color:var(--text);
  outline:none;
  font-size:14px;
}

/* focus state */
input:focus,
select:focus{
  border-color:rgba(96,165,250,.55);
  box-shadow:0 0 0 5px rgba(59,130,246,.14);
}

/* remove native select styling */
select{
  appearance:none;
  -webkit-appearance:none;
  -moz-appearance:none;
  cursor:pointer;

  /* custom arrow */
  background-image:
    linear-gradient(45deg, transparent 50%, #9fb0c6 50%),
    linear-gradient(135deg, #9fb0c6 50%, transparent 50%);
  background-position:
    calc(100% - 18px) calc(50% - 3px),
    calc(100% - 12px) calc(50% - 3px);
  background-size:6px 6px;
  background-repeat:no-repeat;
}

/* option background for dark theme */
select option{
  background:#0b1220;
  color:var(--text);
}

</style>

<script>
  const form = document.getElementById("registerForm");
  const err = document.getElementById("err");

  function showError(message) {
    err.textContent = message;
    err.hidden = false;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    err.hidden = true;
    err.textContent = "";

    const payload = {
      name: document.getElementById("name").value.trim(),
      email: document.getElementById("email").value.trim(),
      password: document.getElementById("password").value,
      userType: document.getElementById("userType").value
    };

    let res;
    try {
      res = await fetch("/api/users/register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        body: JSON.stringify(payload)
      });
    } catch {
      showError("Network error. Please check your connection and try again.");
      return;
    }

    if (!res.ok) {
  let data = null;

  // Try to read JSON, but don't crash if it isn't JSON
  try {
    data = await res.json();
  } catch {
    showError("Registration failed. Please try again.");
    return;
  }

  // ✅ 1) ASP.NET Core validation errors: { errors: { Field: [msg] } }
  if (data?.errors && typeof data.errors === "object") {
    const msgs = [];

    for (const [field, arr] of Object.entries(data.errors)) {
      if (Array.isArray(arr) && arr.length) {
        // field might be "$" or "request" etc — ignore name, show message
        msgs.push(arr[0]);
      }
    }

    if (msgs.length) {
      showError(msgs[0]); // or msgs.join("\n") if you want multiple
      return;
    }
  }

  // ✅ 2) Your custom ProblemDetails mapping (from ResultActionResultExtensions)
  if (data?.extensions?.errors?.length) {
    showError(data.extensions.errors[0].message);
    return;
  }

  if (data?.detail) {
    showError(data.detail);
    return;
  }

  // ✅ 3) Final fallback
  showError("Registration failed. Please try again.");
  return;
}

    // success → go to login
    window.location.href = "auth/login";
  });
</script>

